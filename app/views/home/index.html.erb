<h1>🚨 Dashboard</h1>
<h2 style="font-size:15px;color:#555;font-weight:400;margin-top:0;">Welcome back — here's where you stand today.</h2>

<h3 style="margin-bottom:6px;">Revenue</h3>
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px;">
  <div style="padding:16px;border:1px solid #ddd;border-radius:8px;">
    <div style="font-size:11px;color:#888;text-transform:uppercase;">Unpaid Invoices</div>
    <div style="font-size:26px;font-weight:700;color:#856404;">$<%= number_with_precision(@unpaid_total, precision: 2, delimiter: ',') %></div>
  </div>
  <div style="padding:16px;border:1px solid #ddd;border-radius:8px;">
    <div style="font-size:11px;color:#888;text-transform:uppercase;">Collected This Month</div>
    <div style="font-size:26px;font-weight:700;color:#155724;">$<%= number_with_precision(@paid_mtd, precision: 2, delimiter: ',') %></div>
  </div>
  <div style="padding:16px;border:1px solid #ddd;border-radius:8px;">
    <div style="font-size:11px;color:#888;text-transform:uppercase;">YTD Revenue</div>
    <div style="font-size:26px;font-weight:700;color:#155724;">$<%= number_with_precision(@ytd_revenue, precision: 2, delimiter: ',') %></div>
  </div>
</div>

<h3 style="margin-bottom:6px;">Expenses</h3>
<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:20px;">
  <div style="padding:16px;border:1px solid #ddd;border-radius:8px;">
    <div style="font-size:11px;color:#888;text-transform:uppercase;">Expenses This Month</div>
    <div style="font-size:26px;font-weight:700;color:#721c24;">$<%= number_with_precision(@expenses_mtd, precision: 2, delimiter: ',') %></div>
  </div>
  <div style="padding:16px;border:1px solid #ddd;border-radius:8px;">
    <div style="font-size:11px;color:#888;text-transform:uppercase;">YTD Expenses</div>
    <div style="font-size:26px;font-weight:700;color:#721c24;">$<%= number_with_precision(@ytd_expenses, precision: 2, delimiter: ',') %></div>
  </div>
</div>

<h3 style="margin-bottom:6px;">Performance</h3>
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px;">
  <div style="padding:16px;border:1px solid #ddd;border-radius:8px;">
    <div style="font-size:11px;color:#888;text-transform:uppercase;">Total Miles</div>
    <div style="font-size:26px;font-weight:700;"><%= number_with_delimiter(@total_miles.round) %></div>
  </div>
  <div style="padding:16px;border:1px solid #ddd;border-radius:8px;">
    <div style="font-size:11px;color:#888;text-transform:uppercase;">Rev / Mile</div>
    <div style="font-size:26px;font-weight:700;"><%= @rpm ? "$#{@rpm}" : '—' %></div>
  </div>
  <div style="padding:16px;border:1px solid #ddd;border-radius:8px;">
    <div style="font-size:11px;color:#888;text-transform:uppercase;">Cost / Mile</div>
    <div style="font-size:26px;font-weight:700;"><%= @cpm ? "$#{@cpm}" : '—' %></div>
  </div>
  <div style="padding:16px;border:1px solid #ddd;border-radius:8px;">
    <div style="font-size:11px;color:#888;text-transform:uppercase;">Overall MPG</div>
    <div style="font-size:26px;font-weight:700;"><%= @overall_mpg || '—' %></div>
  </div>
</div>

<% if @recent_unpaid.any? %>
  <h3>Outstanding Invoices</h3>
  <table style="width:100%;border-collapse:collapse;font-size:14px;">
    <thead>
      <tr style="background:#f5f5f5;">
        <th style="text-align:left;padding:8px;">Invoice #</th>
        <th style="text-align:left;padding:8px;">Date</th>
        <th style="text-align:left;padding:8px;">Customer</th>
        <th style="text-align:right;padding:8px;">Amount</th>
        <th style="padding:8px;"></th>
      </tr>
    </thead>
    <tbody>
      <% @recent_unpaid.each do |inv| %>
        <tr style="border-bottom:1px solid #eee;">
          <td style="padding:8px;"><%= inv.invoice_number %></td>
          <td style="padding:8px;"><%= inv.invoice_date %></td>
          <td style="padding:8px;"><%= inv.customer_name %></td>
          <td style="padding:8px;text-align:right;color:#856404;font-weight:700;">$<%= number_with_precision(inv.amount, precision: 2) %></td>
          <td style="padding:8px;"><%= link_to "Edit", edit_invoice_path(inv), style: "font-size:12px;" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
