<p style="color: green"><%= notice %></p>

<% content_for :title, "Expenses" %>

<h1>Expenses</h1>

<%= form_with url: expenses_path, method: :get, local: true, style: "display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;max-width:700px;margin-bottom:12px;" do |f| %>
  <div>
    <%= f.label :start_date, "Start Date", style: "display:block;font-weight:600;" %>
    <%= f.date_field :start_date, value: @start_date %>
  </div>
  <div>
    <%= f.label :end_date, "End Date", style: "display:block;font-weight:600;" %>
    <%= f.date_field :end_date, value: @end_date %>
  </div>
  <div style="align-self:end;display:flex;gap:8px;">
    <%= f.submit "Filter", style: "padding:10px 14px;font-weight:700;" %>
  </div>
<% end %>

<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;">
  <%= link_to "Export Expense Report (CSV)", expenses_path(format: :csv, start_date: @start_date, end_date: @end_date), style: "padding:10px 14px;font-weight:700;display:inline-block;" %>
  <%= link_to "New Expense", new_expense_path, style: "padding:10px 14px;font-weight:700;display:inline-block;" %>
</div>

<div id="expenses">
  <% @expenses.each do |expense| %>
    <%= render expense %>
    <div style="margin-bottom:6px;">
      <%= link_to "Show", expense %> |
      <%= link_to "Edit", edit_expense_path(expense) %>
    </div>
  <% end %>
</div>
