<% content_for :title, "Create Account" %>

<h1>Create Account</h1>
<p style="margin-top:0;">Each account gets its own secure cloud workspace.</p>

<% if @user.errors.any? %>
  <div style="color:#721c24;">
    <h3><%= pluralize(@user.errors.count, "error") %> stopped signup:</h3>
    <ul>
      <% @user.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @user, url: signup_path, method: :post, local: true, style: "max-width:420px;display:grid;gap:10px;" do |f| %>
  <div>
    <%= f.label :email, "Email", style: "display:block;font-weight:600;" %>
    <%= f.email_field :email, required: true %>
  </div>
  <div>
    <%= f.label :password, "Password", style: "display:block;font-weight:600;" %>
    <%= f.password_field :password, required: true %>
  </div>
  <div>
    <%= f.label :password_confirmation, "Confirm Password", style: "display:block;font-weight:600;" %>
    <%= f.password_field :password_confirmation, required: true %>
  </div>
  <div>
    <%= f.submit "Create Account", style: "padding:12px 14px;font-weight:700;" %>
  </div>
<% end %>

<p style="margin-top:10px;">Already have an account? <%= link_to "Sign in", login_path %></p>
