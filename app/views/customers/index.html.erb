<h1>👥 Customer Analysis</h1>
<p style="color:#555;margin-top:0;">Auto-built from your invoice history.</p>

<% if @customers.empty? %>
	<p style="color:#888;">No invoices yet — customer analysis will appear here once you add invoices.</p>
<% else %>

	<%# --- Summary cards --- %>
	<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:24px;">
		<div style="padding:16px;border:1px solid #ddd;border-radius:8px;text-align:center;">
			<div style="font-size:26px;font-weight:700;"><%= @customers.size %></div>
			<div style="font-size:12px;color:#555;text-transform:uppercase;">Total Customers</div>
		</div>
		<div style="padding:16px;border:1px solid #ddd;border-radius:8px;text-align:center;">
			<div style="font-size:20px;font-weight:700;"><%= @top_customer[:name] %></div>
			<div style="font-size:12px;color:#555;text-transform:uppercase;">Top Customer</div>
			<div style="font-size:13px;color:#155724;">$<%= number_with_precision(@top_customer[:total_revenue], precision: 2, delimiter: ',') %> revenue</div>
		</div>
		<div style="padding:16px;border:1px solid #ddd;border-radius:8px;text-align:center;">
			<div style="font-size:26px;font-weight:700;">$<%= number_with_precision(@avg_customer_value, precision: 2, delimiter: ',') %></div>
			<div style="font-size:12px;color:#555;text-transform:uppercase;">Avg Customer Value</div>
		</div>
	</div>

	<%# --- Table --- %>
	<table style="width:100%;border-collapse:collapse;font-size:14px;">
		<thead>
			<tr style="background:#f5f5f5;">
				<th style="text-align:left;padding:10px;border-bottom:2px solid #ddd;">Customer</th>
				<th style="text-align:center;padding:10px;border-bottom:2px solid #ddd;">Invoices</th>
				<th style="text-align:right;padding:10px;border-bottom:2px solid #ddd;">Total Revenue</th>
				<th style="text-align:right;padding:10px;border-bottom:2px solid #ddd;">Avg Invoice</th>
				<th style="text-align:center;padding:10px;border-bottom:2px solid #ddd;">Unpaid</th>
				<th style="text-align:center;padding:10px;border-bottom:2px solid #ddd;">Payment Rate</th>
			</tr>
		</thead>
		<tbody>
			<% @customers.each do |c| %>
				<tr style="border-bottom:1px solid #eee;">
					<td style="padding:10px;font-weight:600;"><%= c[:name] %></td>
					<td style="padding:10px;text-align:center;"><%= c[:invoice_count] %></td>
					<td style="padding:10px;text-align:right;color:#155724;font-weight:700;">$<%= number_with_precision(c[:total_revenue], precision: 2, delimiter: ',') %></td>
					<td style="padding:10px;text-align:right;">$<%= number_with_precision(c[:avg_invoice], precision: 2) %></td>
					<td style="padding:10px;text-align:center;<%= c[:unpaid_count] > 0 ? 'color:#856404;font-weight:700;' : '' %>">
						<%= c[:unpaid_count] > 0 ? c[:unpaid_count] : '—' %>
					</td>
					<td style="padding:10px;text-align:center;">
						<% rate = c[:payment_rate] %>
						<span style="padding:3px 8px;border-radius:12px;font-size:12px;font-weight:700;
							background:<%= rate == 100 ? '#d4edda' : rate >= 50 ? '#fff3cd' : '#f8d7da' %>;
							color:<%= rate == 100 ? '#155724' : rate >= 50 ? '#856404' : '#721c24' %>;">
							<%= rate %>% paid
						</span>
					</td>
				</tr>
			<% end %>
		</tbody>
	</table>

<% end %>
