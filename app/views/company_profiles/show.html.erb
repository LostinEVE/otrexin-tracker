<p style="color: green"><%= notice %></p>

<% content_for :title, "Company Profile" %>

<h1>Company Profile</h1>
<p style="margin-top:0;">This information appears on invoice headers and reports.</p>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;max-width:820px;margin-bottom:18px;">
  <div style="padding:14px;border:1px solid #d8dee8;border-radius:12px;background:#fff;">
    <div style="font-size:12px;color:#66748a;">Company</div>
    <div style="font-size:18px;font-weight:700;"><%= @company_profile.company_name.presence || "Add Company Name" %></div>
  </div>
  <div style="padding:14px;border:1px solid #d8dee8;border-radius:12px;background:#fff;">
    <div style="font-size:12px;color:#66748a;">Address</div>
    <div><%= @company_profile.address_line1 %></div>
    <div><%= @company_profile.address_line2 %></div>
    <div><%= @company_profile.city_state_zip %></div>
  </div>
  <div style="padding:14px;border:1px solid #d8dee8;border-radius:12px;background:#fff;">
    <div style="font-size:12px;color:#66748a;">Contact</div>
    <div><%= @company_profile.phone %></div>
    <div><%= @company_profile.email %></div>
    <div>DOT: <%= @company_profile.dot_number %></div>
    <div>MC: <%= @company_profile.mc_number %></div>
  </div>
</div>

<%= link_to "Edit Company Profile", edit_company_profile_path, style: "padding:10px 16px;font-weight:700;display:inline-block;" %>
