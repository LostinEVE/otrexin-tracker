<p style="color: green"><%= notice %></p>

<% content_for :title, "Mileage Tracker" %>

<h1>🚨 Mileage Tracker</h1>

<% total_miles = @total_miles %>
<% total_rev   = @total_revenue %>
<% rpm         = @revenue_per_mile %>
<% cpm         = @cost_per_mile %>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px;">
  <div style="padding:14px;border:1px solid #ddd;border-radius:8px;text-align:center;">
    <div style="font-size:22px;font-weight:700;"><%= number_with_delimiter(total_miles.round) %></div>
    <div style="font-size:12px;color:#555;">Total Miles</div>
  </div>
  <div style="padding:14px;border:1px solid #ddd;border-radius:8px;text-align:center;">
    <div style="font-size:22px;font-weight:700;">$<%= number_with_precision(total_rev, precision: 2, delimiter: ',') %></div>
    <div style="font-size:12px;color:#555;">Total Revenue</div>
  </div>
  <div style="padding:14px;border:1px solid #ddd;border-radius:8px;text-align:center;">
    <div style="font-size:22px;font-weight:700;"><%= rpm ? "$#{rpm}" : '—' %></div>
    <div style="font-size:12px;color:#555;">Rev / Mile</div>
  </div>
  <div style="padding:14px;border:1px solid #ddd;border-radius:8px;text-align:center;">
    <div style="font-size:22px;font-weight:700;"><%= cpm ? "$#{cpm}" : '—' %></div>
    <div style="font-size:12px;color:#555;">Cost / Mile (from Expenses)</div>
  </div>
</div>

<div id="mileages">
  <% @mileages.each do |mileage| %>
    <%= render mileage %>
    <div style="margin-bottom:4px;font-size:13px;">
      <%= link_to "Edit", edit_mileage_path(mileage) %> |
      <%= link_to "Delete", mileage, data: { turbo_method: :delete, turbo_confirm: "Delete this trip?" } %>
    </div>
  <% end %>
</div>

<%= link_to "+ Log a Trip", new_mileage_path, style: "padding:12px 20px;font-weight:700;display:inline-block;margin-top:10px;" %>
